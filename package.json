  "description": "Patrik Elfström",
  "author": "Patrik Elfström <me@patrikelfstrom.se> (https://patrikelfstrom.se)",
  "homepage": "https://github.com/PatrikElfstrom/patrikelfstrom.se#readme",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "typecheck": "tsc --pretty --noEmit",
    "lint": "eslint src/**/*.{ts,astro} --fix",
    "verify": "pnpm astro check; pnpm typecheck; pnpm lint; pnpm test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "update": "pnpx npm-check-updates --interactive --upgrade --format group"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PatrikElfstrom/patrikelfstrom.se.git"
  },
  "bugs": {
    "url": "https://github.com/PatrikElfstrom/patrikelfstrom.se/issues"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.1",
    "color-convert": "^3.1.3",
    "debounce-fn": "^6.0.0",
    "pixi.js": "^8.17.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "volta": {
    "node": "24.14.1"
  }
}
