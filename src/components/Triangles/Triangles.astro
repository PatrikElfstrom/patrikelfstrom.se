<canvas class="pointer-events-none fixed inset-0 -z-10 block h-full w-full"></canvas>

<script>
  import { createTriangleGrid } from './triangleGrid';

  const canvas = document.querySelector('canvas');

  if (canvas instanceof HTMLCanvasElement) {
    void createTriangleGrid({
      backgroundColor: 0x21_21_21,
      resizeTo: document.body,
      size: 40,
      canvas,
      resolution: window.devicePixelRatio || 1,
      autoDensity: true,
    });
  }
</script>
