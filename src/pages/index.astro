---
import Layout from '../layouts/Layout.astro';
import GithubMark from '../assets/githubMark.svg';
---

<Layout title="Patrik Elfström">
  <div class="selection:bg-patrik-blue flex h-[40vh] flex-col self-end selection:text-white">
    <header class="m-2">
      <h1 class="m-0 text-4xl font-bold text-white">Patrik Elfström</h1>
    </header>
    <main id="site" class="m-2">
      <a
        class="text-white no-underline opacity-75 transition-opacity duration-200 ease-in-out hover:opacity-100"
        href="mailto:me@patrikelfstrom.se"
        >me@patrikelfstrom.se
      </a>
    </main>
    <footer class="m-2">
      <small class="text-gray-400">Web Developer</small>
    </footer>
    <aside class="m-2 mt-auto mb-11 text-center">
      <a
        class="text-white no-underline opacity-30 transition-opacity duration-200 ease-in-out hover:opacity-100"
        href="https://github.com/PatrikElfstrom"
        target="_blank"
        rel="noreferrer"
        aria-label="Github Profile"
      >
        <GithubMark class="inline" />
      </a>
    </aside>
  </div>
</Layout>
